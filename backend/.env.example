# Tableau Server / Cloud
TABLEAU_SERVER_URL=https://your-tableau-server.example.com
TABLEAU_SITE_ID=                        # empty string for Default site
TABLEAU_PAT_NAME=your-pat-name
TABLEAU_PAT_SECRET=your-pat-secret

# LLM
LLM_PROVIDER=claude                     # claude | openai | gemini
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=                         # only needed if LLM_PROVIDER=openai
GOOGLE_API_KEY=                         # only needed if LLM_PROVIDER=gemini

# Agent behaviour
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.0
AGENT_MAX_TOOL_ROUNDS=10

# Server
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
